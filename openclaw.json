{
    "agents": {
        "list": [
            {
                "id": "thu-ky-tieu-my",
                "default": true,
                "workspace": "${STAFF_HOME}/thu-ky-tieu-my",
                "model": "${TIEU_MY_MODEL}"
            },
            {
                "id": "mr-insight",
                "workspace": "${STAFF_HOME}/mr-insight",
                "model": "${INSIGHT_MODEL}"
            },
            {
                "id": "mr-logic",
                "workspace": "${STAFF_HOME}/mr-logic",
                "model": "${LOGIC_MODEL}"
            },
            {
                "id": "mr-strategy",
                "workspace": "${STAFF_HOME}/mr-strategy",
                "model": "${STRATEGY_MODEL}"
            }
        ]
    },
    "channels": {
        "telegram": {
            "enabled": true,
            "streaming": "partial",
            "accounts": {
                "default": {
                    "name": "Thư ký Tiểu My",
                    "botToken": "${TELEGRAM_TIEU_MY_TOKEN}",
                    "dmPolicy": "allowlist",
                    "allowFrom": [
                        "${TELEGRAM_OWNER_ID}"
                    ]
                },
                "insight": {
                    "name": "Mr. Insight",
                    "botToken": "${TELEGRAM_INSIGHT_TOKEN}",
                    "dmPolicy": "allowlist",
                    "allowFrom": [
                        "${TELEGRAM_OWNER_ID}"
                    ]
                },
                "logic": {
                    "name": "Mr. Logic",
                    "botToken": "${TELEGRAM_LOGIC_TOKEN}",
                    "dmPolicy": "allowlist",
                    "allowFrom": [
                        "${TELEGRAM_OWNER_ID}"
                    ]
                },
                "strategy": {
                    "name": "Mr. Strategy",
                    "botToken": "${TELEGRAM_STRATEGY_TOKEN}",
                    "dmPolicy": "allowlist",
                    "allowFrom": [
                        "${TELEGRAM_OWNER_ID}"
                    ]
                }
            }
        }
    },
    "bindings": [
        {
            "agentId": "thu-ky-tieu-my",
            "match": {
                "channel": "telegram",
                "accountId": "default"
            }
        },
        {
            "agentId": "mr-insight",
            "match": {
                "channel": "telegram",
                "accountId": "insight"
            }
        },
        {
            "agentId": "mr-logic",
            "match": {
                "channel": "telegram",
                "accountId": "logic"
            }
        },
        {
            "agentId": "mr-strategy",
            "match": {
                "channel": "telegram",
                "accountId": "strategy"
            }
        }
    ],
    "plugins": {
        "slots": {
            "memory": "neuralmemory"
        }
    },
    "tools": {
        "agentToAgent": {
            "enabled": true
        },
        "sessions": {
            "visibility": "all"
        }
    },
    "cron": {
        "enabled": true
    },
    "session": {
        "dmScope": "per-account-channel-peer"
    },
    "gateway": {
        "mode": "local"
    }
}