# ===== Telegram Bot Tokens =====
# Lấy từ @BotFather trên Telegram
TELEGRAM_TIEU_MY_TOKEN=your_tieu_my_bot_token_here
TELEGRAM_INSIGHT_TOKEN=your_mr_insight_bot_token_here
TELEGRAM_LOGIC_TOKEN=your_mr_logic_bot_token_here
TELEGRAM_STRATEGY_TOKEN=your_mr_strategy_bot_token_here

# ===== Telegram Owner =====
# Telegram User ID của bạn (lấy bằng cách gửi /start cho @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ===== Web Search =====
# Tavily API key (free tier: 1000 calls/tháng) — https://tavily.com
# Nếu hết quota, OpenClaw tự fallback sang Gemini Google Search grounding
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Model cho từng agent =====
# Đổi model riêng cho từng agent nếu cần (VD: Thư ký dùng model mạnh hơn)
TIEU_MY_MODEL=gemini-3.0-flash
INSIGHT_MODEL=gemini-3.0-flash
LOGIC_MODEL=gemini-3.0-flash
STRATEGY_MODEL=gemini-3.0-flash

# ===== LLM API Key =====
# Google API key cho Gemini
GOOGLE_API_KEY=your_google_api_key_here

# ===== NeuralMemory =====
# Không cần config thêm — plugin tự khởi tạo brain khi chạy lần đầu
