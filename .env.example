# ===== Staff Home =====
# Đường dẫn tuyệt đối tới thư mục my-staff trên VPS
# VD: /root/my-staff hoặc /home/ubuntu/my-staff
STAFF_HOME=/root/my-staff

# ===== Telegram Bot Tokens =====
# Lấy từ @BotFather trên Telegram — mỗi agent 1 bot
TELEGRAM_TIEU_MY_TOKEN=your_tieu_my_bot_token_here
TELEGRAM_INSIGHT_TOKEN=your_mr_insight_bot_token_here
TELEGRAM_LOGIC_TOKEN=your_mr_logic_bot_token_here
TELEGRAM_STRATEGY_TOKEN=your_mr_strategy_bot_token_here

# ===== Telegram Owner =====
# Telegram User ID của bạn (lấy bằng cách gửi /start cho @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ===== Web Search =====
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Model cho từng agent =====
# Format: provider/model
# Docs liệt kê: google/gemini-3-flash-preview, google/gemini-3-pro-preview,
#   anthropic/claude-sonnet-4-5, anthropic/claude-opus-4-6, openai/gpt-5.2
# ⚠️ Kiểm tra model name chính xác: openclaw config get agents.defaults.models
TIEU_MY_MODEL=google/gemini-flash-latest
INSIGHT_MODEL=google/gemini-flash-latest
LOGIC_MODEL=google/gemini-flash-latest
STRATEGY_MODEL=google/gemini-flash-latest

# Đổi sang Vertex AI:
# TIEU_MY_MODEL=google-vertex/gemini-flash-latest
# INSIGHT_MODEL=google-vertex/gemini-flash-latest
# LOGIC_MODEL=google-vertex/gemini-flash-latest
# STRATEGY_MODEL=google-vertex/gemini-flash-latest


# ╔══════════════════════════════════════════════════════════════════╗
# ║         CHỌN 1 TRONG 2 PHƯƠNG THỨC XÁC THỰC GOOGLE            ║
# ║         (Uncomment phương thức bạn muốn dùng)                  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────
# PHƯƠNG THỨC 1: Google AI Studio API Key (miễn phí, có rate limit)
# ──────────────────────────────────────────────────────────────────
# Tạo key tại: https://aistudio.google.com/apikey
# Dùng với provider: google/gemini-xxx
# Có thể tạo nhiều key từ nhiều project để tránh rate limit

# ===== LLM API Keys (mỗi agent 1 key riêng để tránh rate limit) =====
GOOGLE_API_KEY_TIEU_MY=your_tieu_my_api_key_here
GOOGLE_API_KEY_INSIGHT=your_insight_api_key_here
GOOGLE_API_KEY_LOGIC=your_logic_api_key_here
GOOGLE_API_KEY_STRATEGY=your_strategy_api_key_here

# ===== Mem0 Memory (Open Source — dùng Gemini, $0) =====
# Mem0 OSS đọc GOOGLE_API_KEY cho cả LLM + Embedder
# Dùng chung 1 trong 4 key ở trên (hoặc tạo key riêng)
GOOGLE_API_KEY=your_google_api_key_here

# ──────────────────────────────────────────────────────────────────
# PHƯƠNG THỨC 2: Vertex AI Service Account JSON (paid, higher quota)
# ──────────────────────────────────────────────────────────────────
# Tạo Service Account tại: Google Cloud Console → IAM → Service Accounts
# Download JSON key → đặt vào folder vertex-ai/
# Dùng với provider: google-vertex/gemini-xxx
#
# GOOGLE_APPLICATION_CREDENTIALS=${STAFF_HOME}/vertex-ai/your-service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
#
# ⚠️ Yêu cầu:
#   - Bật Vertex AI API trong Google Cloud Console
#   - Service account cần role: Vertex AI User
#   - Billing phải enabled (Vertex AI là paid service)
#   - Folder vertex-ai/ đã được gitignore — an toàn

# ──────────────────────────────────────────────────────────────────
# API Keys cho các provider khác (nếu dùng)
# ──────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
